# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ORGANIZER_PASSWORD: Password to access the Organizer Portal dashboard.
ORGANIZER_PASSWORD="EverAfter2026"

# SUPABASE_URL: The API URL of your remote Supabase instance.
SUPABASE_URL="https://pvuszjcuvkycprbggweo.supabase.co"
VITE_SUPABASE_URL="https://pvuszjcuvkycprbggweo.supabase.co"

# SUPABASE_ANON_KEY: The public/anonymous key for Supabase.
SUPABASE_ANON_KEY="sb_publishable_xPvR3HkIozZaxNLxPCIRfw_dvljpvdV"
VITE_SUPABASE_ANON_KEY="sb_publishable_xPvR3HkIozZaxNLxPCIRfw_dvljpvdV"

# VITE_WEDDING_SLUG: Restricts the portal and site to this specific couple.
